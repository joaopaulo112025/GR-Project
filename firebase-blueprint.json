{
  "entities": {
    "schedule": {
      "title": "Schedule",
      "description": "A scheduled meeting slot for GR Plano de ação",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique schedule identifier"
        },
        "vendedor": {
          "type": "string",
          "description": "Name of the seller booking the slot"
        },
        "projeto": {
          "type": "string",
          "description": "Name of the project (GR Plano de ação)"
        },
        "data": {
          "type": "string",
          "description": "The selected date (YYYY-MM-DD)"
        },
        "horario": {
          "type": "string",
          "description": "Selected 45-minute time slot identifier"
        },
        "createdAt": {
          "type": "string",
          "description": "Creation timestamp in ISO format"
        }
      },
      "required": ["id", "vendedor", "projeto", "data", "horario", "createdAt"]
    },
    "notification": {
      "title": "Notification",
      "description": "A logged email notification or simulator message",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique notification identifier"
        },
        "to": {
          "type": "string",
          "description": "Recipient email address"
        },
        "subject": {
          "type": "string",
          "description": "Email subject"
        },
        "body": {
          "type": "string",
          "description": "HTML or plain text body of the email"
        },
        "status": {
          "type": "string",
          "description": "Trigger status (Simulado, Enviado, Erro)"
        },
        "errorDetails": {
          "type": "string",
          "description": "Optional SMTP connection error detail string"
        },
        "createdAt": {
          "type": "string",
          "description": "Log creation timestamp"
        }
      },
      "required": ["id", "to", "subject", "body", "status", "createdAt"]
    }
  },
  "firestore": {
    "/schedules/{scheduleId}": {
      "schema": "schedule",
      "description": "Collection of all booked meetings"
    },
    "/notifications/{notificationId}": {
      "schema": "notification",
      "description": "Logs of automatic and simulated email notifications"
    }
  }
}
